{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Multimedia Downloader",
  "version": "4.3.3",
  "identifier": "com.spacesquare.multimedia-downloader",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:frontend",
    "beforeBuildCommand": "npm run build:frontend"
  },
  "app": {
    "windows": [
      {
        "title": "Multimedia Downloader",
        "width": 820,
        "height": 720,
        "minWidth": 600,
        "minHeight": 520,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico", "icons/icon.icns"],
    "resources": {
      "../packaging/dist/engine_sidecar": "engine_sidecar"
    },
    "windows": {
      "nsis": { "installMode": "currentUser" }
    }
  }
}
